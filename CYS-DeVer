		Notification("Notification", "Anti-Ragdoll", "Anti-Ragdoll: OFF")
	end
end)

WHColorButton.Activated:Connect(function()
	if WHColorButton:GetAttribute("Active") == true then
		WHColorButton:SetAttribute("Active", false)
		WHColorChooseFrame.Visible = false
	else
		WHColorButton:SetAttribute("Active", true)
		WHColorChooseFrame.Visible = true
	end
end)

WHSwitchButton.Activated:Connect(function()
	SwitcherSetup(WHSwitchButton)
	if WHSwitchButton:GetAttribute("Switch") == true then

		Notification("Notification", "Wall Hack", "Wall Hack ON")

		for _, v in workspace:GetChildren() do
			if v:IsA("Model") and v:FindFirstChild("Humanoid") and v ~= Character then
				WallHackHL(v)
			end
		end
	else

		Notification("Notification", "Wall Hack", "Wall Hack OFF")

		for _, v in workspace:GetDescendants() do
			if v:IsA("Highlight") and v.Name == "WallHackHL" then
				TS:Create(v, TweenInfo.new(0.25, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {OutlineTransparency = 1}):Play()
				task.delay(0.25, function()
					v:Destroy()
				end)
			end
		end
	end
end)

CloseButton.Activated:Connect(function()
	UiClose:Play()
	CloseButton.Interactable = false
	TS:Create(Background, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), {Size = UDim2.new(0, 0, 0, 0)}):Play()

	task.delay(0.2, function()
		ButtonTag.Position = Background.Position
		ButtonTag.Visible = true
		Background.Visible = false
		ButtonTag.Interactable = true
	end)
end)

ButtonTag.Activated:Connect(function()
	UiOpen:Play()
	ButtonTag.Interactable = false
	TS:Create(Background, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), {Size = UDim2.new(0.277, 0, 0.282, 0)}):Play()
	Background.Visible = true
	CloseButton.Interactable = true

	task.delay(0.25, function()
		ButtonTag.Visible = false
	end)
end)

