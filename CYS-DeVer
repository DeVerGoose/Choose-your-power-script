local function AddChangelog(Version, Date, MainInfo)
	local NewLog = Example:Clone()
	NewLog.Name = Version
	NewLog:FindFirstChild("VersionLabel").Text = Version
	NewLog:FindFirstChild("DateLabel").Text = Date
	NewLog:FindFirstChild("MainLabel").Text = MainInfo
	NewLog.Parent = Container
	NewLog.Visible = true
end

local function StartInfiniteRotation(Object)
	local function PlayNextTween()
		local RandomOffset = math.random(-35, 35)
		local Duration = math.random(80, 250) / 100

		local Tween = TS:Create(Object, TweenInfo.new(Duration, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), {Rotation = Object.Rotation + RandomOffset})
		Tween.Completed:Connect(function()
			PlayNextTween()
		end)

		Tween:Play()
	end

	PlayNextTween()
end

for _, Item in StartGui:GetDescendants() do
	if Item:HasTag("RandomRotation") then
		StartInfiniteRotation(Item)
	end
end

