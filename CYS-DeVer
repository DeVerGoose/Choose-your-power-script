local function TopFrameButtonSetup(Button)
	if Button == CurrentPage then return end
	UiClick:Play()
	CurrentPage = Button

	for _, v in PagesFolder:GetChildren()  do
		if v ~= Button.Name then

		end
	end

	if math.random(1, 2) == 1 then
